/* pages/home/home.wxss */
.home-container {
  min-height: 100vh;
  background: var(--color-bg);
}

/* Header */
.home-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 100rpx 40rpx 32rpx;
  background: var(--color-bg);
}
.greeting {
  font-size: 24rpx;
  color: var(--color-brown);
  letter-spacing: 2rpx;
  display: block;
}
.header-title {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-top: 4rpx;
  display: block;
}
.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-gold);
}

/* 搜索栏 */
.search-bar-wrap {
  padding: 0 40rpx 24rpx;
}
.search-bar {
  background: var(--color-bg-card);
  border-radius: 48rpx;
  border: 1rpx solid var(--color-border);
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(26,20,16,0.06);
}
.search-icon { font-size: 32rpx; margin-right: 16rpx; }
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text);
  background: transparent;
}
.search-clear {
  font-size: 40rpx;
  color: var(--color-brown);
  opacity: 0;
  transition: opacity 0.2s;
  line-height: 1;
}
.search-clear.show { opacity: 1; }

/* 搜索结果 */
.search-results { padding: 0 40rpx; }
.section-label {
  font-size: 24rpx;
  color: var(--color-brown);
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}
.empty-hint {
  text-align: center;
  padding: 80rpx 0;
  color: var(--color-text-sub);
  font-size: 28rpx;
}
.book-list-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  align-items: flex-start;
}
.book-cover-sm {
  width: 100rpx;
  height: 140rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  box-shadow: 4rpx 4rpx 12rpx rgba(26,20,16,0.15);
}
.book-list-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  margin-bottom: 8rpx;
}
.book-list-author {
  font-size: 24rpx;
  color: var(--color-text-sub);
  display: block;
  margin-bottom: 12rpx;
}
.book-list-tags { display: flex; flex-wrap: wrap; gap: 8rpx; }
.book-list-tag {
  font-size: 20rpx;
  color: var(--color-brown);
  background: rgba(139,115,85,0.1);
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}

/* 滚动区 */
.home-scroll { height: calc(100vh - 320rpx); }

/* section 通用 */
.section-header {
  padding: 0 40rpx;
  margin-bottom: 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
}
.section-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text);
}
.section-ornament {
  flex: 1;
  height: 1rpx;
  background: linear-gradient(to right, var(--color-gold), transparent);
  opacity: 0.4;
}

/* 精选大卡 */
.featured-section { padding: 20rpx 0 40rpx; }
.featured-card {
  margin: 0 40rpx;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
  height: 480rpx;
  box-shadow: 0 12rpx 40rpx rgba(26,20,16,0.2);
}
.featured-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.featured-overlay {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  padding: 48rpx 40rpx 40rpx;
  background: linear-gradient(to top, rgba(26,20,16,0.92) 60%, transparent);
}
.featured-categories {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.featured-tag {
  font-size: 20rpx;
  color: var(--color-gold);
  border: 1rpx solid var(--color-gold);
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
}
.featured-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}
.featured-author {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  display: block;
  margin-bottom: 28rpx;
}
.featured-action {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: var(--color-gold);
  font-weight: 500;
}
.arrow { font-size: 32rpx; }

/* 书籍网格 */
.recommend-section { padding-bottom: 40rpx; }
.books-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  padding: 0 40rpx;
}

.book-card {
  cursor: pointer;
  animation: fadeInUp 0.4s ease both;
}
.book-card-wide {
  grid-column: span 2;
}
.book-card-tilt .book-cover-wrap {
  transform: rotate(-1.5deg);
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(24rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.book-cover-wrap {
  position: relative;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 4rpx 8rpx 20rpx rgba(26,20,16,0.18);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.book-card:active .book-cover-wrap {
  transform: scale(0.96) !important;
  box-shadow: 2rpx 4rpx 12rpx rgba(26,20,16,0.12);
}

.book-cover {
  width: 100%;
  aspect-ratio: 3/4;
  display: block;
}
.book-card-wide .book-cover {
  aspect-ratio: 16/9;
}

.book-hot {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  background: #E8381A;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.book-info { padding: 12rpx 4rpx 0; }
.book-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.book-author {
  font-size: 22rpx;
  color: var(--color-text-sub);
  display: block;
  margin-top: 4rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

/* 骨架屏 */
.skeleton-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  padding: 0 40rpx;
}
.skeleton-card {}
.sk-cover {
  width: 100%;
  aspect-ratio: 3/4;
  background: linear-gradient(90deg, #EDE8DF 25%, #F5F0E8 50%, #EDE8DF 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
  border-radius: 10rpx;
}
.sk-line {
  height: 20rpx;
  background: linear-gradient(90deg, #EDE8DF 25%, #F5F0E8 50%, #EDE8DF 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
  border-radius: 4rpx;
  margin-top: 12rpx;
}
.sk-line-1 { width: 80%; }
.sk-line-2 { width: 55%; }
@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 加载更多 */
.loading-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  padding: 40rpx 0;
}
.dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--color-gold);
  border-radius: 50%;
  animation: bounce 1.2s infinite ease-in-out;
}
.dot:nth-child(2) { animation-delay: 0.2s; }
.dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.5; }
  40%           { transform: scale(1.0); opacity: 1; }
}

.no-more {
  text-align: center;
  color: var(--color-text-sub);
  font-size: 24rpx;
  padding: 32rpx 0;
  letter-spacing: 4rpx;
}
