/* miniprogram/pages/read/read.wxss */
.read-container {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  transition: background-color 0.3s;
}

.custom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 30rpx;
  z-index: 100;
}

.nav-back {
  width: 60rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  flex: 1;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 0 40rpx;
}

.nav-actions {
  width: 60rpx;
  display: flex;
  justify-content: flex-end;
}

.theme-toggle {
  font-size: 24rpx;
}

.read-swiper {
  flex: 1;
  width: 100%;
}

.page-scroll {
  height: 100%;
}

.page-content {
  padding: 40rpx 40rpx 120rpx;
  box-sizing: border-box;
}

.page-text {
  line-height: 2;
  text-align: justify;
  font-family: 'PingFang SC', 'Heiti SC', sans-serif;
  letter-spacing: 2rpx;
}

.page-footer {
  position: absolute;
  bottom: 60rpx;
  left: 0; right: 0;
  text-align: center;
  font-size: 24rpx;
  color: #999;
}

.ad-page {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
}

.ad-tips {
  font-size: 36rpx;
  color: var(--color-gold);
  margin-bottom: 60rpx;
}

.ad-placeholder {
  width: 100%;
  height: 400rpx;
  background: rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  border-radius: 12rpx;
  margin-bottom: 60rpx;
}

.finish-btn {
  width: 400rpx;
}

.loading-full {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: #F5F0E8;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-text {
  color: #8B7355;
  font-size: 32rpx;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}
