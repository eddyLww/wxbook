/* pages/reader/reader.wxss */
.reader-container {
  height: 100vh;
  overflow: hidden;
  position: relative;
  display: flex;
  flex-direction: column;
  background: #F5F0E8;
}

/* Header */
.reader-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 50;
  display: flex;
  align-items: center;
  padding: 88rpx 32rpx 20rpx;
  background: rgba(254,252,247,0.95);
  backdrop-filter: blur(8px);
  border-bottom: 1rpx solid rgba(201,168,76,0.2);
  transition: transform 0.3s ease;
}
.header-show { transform: translateY(0); }
.header-hide { transform: translateY(-100%); }

.header-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.back-icon {
  font-size: 56rpx;
  color: var(--color-text);
  font-weight: 300;
  line-height: 1;
}
.header-title-wrap {
  flex: 1;
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  padding: 0 16rpx;
  overflow: hidden;
}
.header-book-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-family: var(--font-serif);
}
.header-blogger {
  font-size: 22rpx;
  color: var(--color-gold);
  white-space: nowrap;
  flex-shrink: 0;
}
.settings-icon {
  font-size: 40rpx;
  color: var(--color-brown);
}

/* 书本主体 */
.book-body {
  flex: 1;
  display: flex;
  position: relative;
  margin-top: 160rpx;
  margin-bottom: 80rpx;
  perspective: 2000rpx;
  overflow: hidden;
}

/* 书脊中线 */
.book-spine-center {
  position: absolute;
  top: 0; bottom: 0;
  left: 50%;
  width: 4rpx;
  background: linear-gradient(to bottom, transparent, rgba(139,115,85,0.3), rgba(139,115,85,0.5), rgba(139,115,85,0.3), transparent);
  z-index: 10;
  transform: translateX(-50%);
}

/* 书页基础样式 */
.book-page {
  position: absolute;
  top: 0; bottom: 0;
  width: 50%;
  background: #FEFCF7;
  /* 纸张纹理 */
  background-image:
    repeating-linear-gradient(0deg, transparent, transparent 47rpx, rgba(201,168,76,0.04) 48rpx);
  display: flex;
  flex-direction: column;
}

.page-left {
  left: 0;
  border-right: 1rpx solid rgba(139,115,85,0.15);
  box-shadow: inset -8rpx 0 16rpx rgba(26,20,16,0.06);
}
.page-right {
  right: 0;
  border-left: 1rpx solid rgba(139,115,85,0.15);
  box-shadow: inset 8rpx 0 16rpx rgba(26,20,16,0.06);
}

/* 左页阴影（书脊处） */
.page-shadow-left {
  position: absolute;
  top: 0; bottom: 0;
  right: 0;
  width: 40rpx;
  background: linear-gradient(to left, rgba(26,20,16,0.08), transparent);
  pointer-events: none;
}
.page-shadow-right {
  position: absolute;
  top: 0; bottom: 0;
  left: 0;
  width: 40rpx;
  background: linear-gradient(to right, rgba(26,20,16,0.08), transparent);
  pointer-events: none;
}

/* 翻转页 */
.page-turning {
  position: absolute;
  top: 0; bottom: 0;
  width: 50%;
  transform-style: preserve-3d;
  z-index: 20;
}

/* 翻页正面/背面 */
.page-front, .page-back {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  backface-visibility: hidden;
  background: #FEFCF7;
  background-image: repeating-linear-gradient(0deg, transparent, transparent 47rpx, rgba(201,168,76,0.04) 48rpx);
}
.page-back {
  transform: rotateY(180deg);
  background: #F8F3EA;
}

/* 折叠阴影 */
.fold-shadow {
  position: absolute;
  top: 0; bottom: 0;
  right: 0;
  width: 20rpx;
  background: linear-gradient(to right, rgba(26,20,16,0.15), transparent);
  pointer-events: none;
}

/* 翻页动画 */
.page-turning.flip-forward {
  right: 0;
  transform-origin: left center;
  animation: flipForward 0.5s cubic-bezier(0.645, 0.045, 0.355, 1.000) forwards;
}
.page-turning.flip-backward {
  left: 0;
  transform-origin: right center;
  animation: flipBackward 0.5s cubic-bezier(0.645, 0.045, 0.355, 1.000) forwards;
}

@keyframes flipForward {
  0%   { transform: perspective(2000rpx) rotateY(0deg); }
  100% { transform: perspective(2000rpx) rotateY(-180deg); }
}
@keyframes flipBackward {
  0%   { transform: perspective(2000rpx) rotateY(0deg); }
  100% { transform: perspective(2000rpx) rotateY(180deg); }
}

/* 页面内容 */
.page-inner {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 40rpx 36rpx 32rpx;
  overflow: hidden;
}
.page-header {
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(201,168,76,0.25);
}
.chapter-title {
  font-size: 22rpx;
  color: var(--color-gold);
  font-weight: 600;
  letter-spacing: 2rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  display: block;
}
.page-content { flex: 1; overflow: hidden; }
.content-text {
  font-size: var(--reader-font-size, 30rpx);
  color: var(--color-text);
  line-height: 1.95;
  font-family: var(--font-serif);
  display: block;
  word-break: break-all;
}
.page-footer {
  text-align: center;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(201,168,76,0.15);
}
.page-num {
  font-size: 20rpx;
  color: var(--color-brown);
  font-family: 'Georgia', serif;
}

/* 点击区域提示 */
.tap-hint-left, .tap-hint-right {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 48rpx;
  height: 80rpx;
  background: rgba(201,168,76,0.15);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: rgba(201,168,76,0.6);
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
  z-index: 5;
}
.tap-hint-left { left: 12rpx; }
.tap-hint-right { right: 12rpx; }
.hint-show { opacity: 1; }

/* Footer 进度 */
.reader-footer {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(254,252,247,0.95);
  backdrop-filter: blur(8px);
  border-top: 1rpx solid rgba(201,168,76,0.2);
  transition: transform 0.3s ease;
}
.footer-show { transform: translateY(0); }
.footer-hide { transform: translateY(100%); }
.progress-text, .progress-pct {
  font-size: 22rpx;
  color: var(--color-brown);
  white-space: nowrap;
}
.progress-bar-wrap {
  flex: 1;
  height: 6rpx;
  background: var(--color-border);
  border-radius: 3rpx;
  overflow: hidden;
}
.progress-bar {
  height: 100%;
  background: linear-gradient(to right, var(--color-gold), #D4AA50);
  border-radius: 3rpx;
  transition: width 0.3s ease;
}

/* 设置面板 */
.settings-panel {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 100;
  pointer-events: none;
}
.settings-panel.panel-show { pointer-events: auto; }
.settings-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(26,20,16,0);
  transition: background 0.3s ease;
}
.settings-panel.panel-show .settings-mask { background: rgba(26,20,16,0.4); }

.settings-content {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: #FEFCF7;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 48rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}
.settings-panel.panel-show .settings-content { transform: translateY(0); }

.settings-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  font-family: var(--font-serif);
  display: block;
  margin-bottom: 40rpx;
  text-align: center;
}
.settings-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 36rpx;
}
.settings-label {
  font-size: 30rpx;
  color: var(--color-text);
}

/* 背景色选项 */
.bg-options { display: flex; gap: 20rpx; }
.bg-circle {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid transparent;
  transition: border-color 0.2s;
}
.bg-circle.bg-active { border-color: var(--color-gold); }

/* 字号控制 */
.font-size-ctrl {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.fs-btn {
  width: 72rpx;
  height: 72rpx;
  border: 2rpx solid var(--color-border);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 600;
}
.fs-val {
  font-size: 28rpx;
  color: var(--color-text);
  min-width: 80rpx;
  text-align: center;
}
