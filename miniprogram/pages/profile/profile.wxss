/* pages/profile/profile.wxss */
.profile-container {
  min-height: 100vh;
  background: var(--color-bg);
}

/* Hero 区 */
.profile-hero {
  position: relative;
  height: 440rpx;
  overflow: hidden;
}
.hero-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #2C2318 0%, #4A3728 50%, #3D2E20 100%);
}
.hero-bg::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background-image: repeating-linear-gradient(
    45deg,
    transparent,
    transparent 60rpx,
    rgba(201,168,76,0.05) 60rpx,
    rgba(201,168,76,0.05) 62rpx
  );
}
.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
}
.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  border: 4rpx solid var(--color-gold);
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.3);
}
.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 32rpx;
}
.profile-stats {
  display: flex;
  gap: 0;
  background: rgba(255,255,255,0.1);
  border-radius: 16rpx;
  padding: 20rpx 48rpx;
  gap: 48rpx;
  align-items: center;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-gold);
  font-family: 'Georgia', serif;
}
.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}
.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255,255,255,0.2);
}

/* 内容区 */
.profile-body { height: calc(100vh - 440rpx - 112rpx); }

.section-card {
  background: var(--color-bg-card);
  border-radius: 20rpx;
  margin: 24rpx 32rpx 0;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(26,20,16,0.06);
}
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}
.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
}
.card-action {
  font-size: 26rpx;
  color: var(--color-gold);
}

/* 兴趣标签 */
.interests-wrap { display: flex; flex-wrap: wrap; gap: 12rpx; }
.interest-tag {
  font-size: 26rpx;
  color: var(--color-brown);
  background: rgba(201,168,76,0.1);
  border: 1rpx solid rgba(201,168,76,0.3);
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
}

/* 喜欢的博主 */
.bloggers-wrap { display: flex; gap: 32rpx; flex-wrap: wrap; }
.fav-blogger { display: flex; flex-direction: column; align-items: center; gap: 8rpx; }
.fav-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(201,168,76,0.4);
}
.fav-name { font-size: 22rpx; color: var(--color-text-sub); }

/* 空状态 */
.empty-tip { font-size: 26rpx; color: var(--color-text-sub); }
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 16rpx;
  gap: 16rpx;
}
.empty-icon { font-size: 64rpx; }
.empty-text { font-size: 26rpx; color: var(--color-text-sub); text-align: center; }
.go-home {
  margin-top: 8rpx;
  padding: 16rpx 48rpx;
}

/* 阅读历史 */
.history-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
}
.history-item:last-child { border-bottom: none; }
.history-cover {
  width: 80rpx;
  height: 112rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
  box-shadow: 3rpx 4rpx 12rpx rgba(26,20,16,0.15);
}
.history-info { flex: 1; min-width: 0; }
.history-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  display: block;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  margin-bottom: 6rpx;
}
.history-blogger {
  font-size: 22rpx;
  color: var(--color-gold);
  display: block;
  margin-bottom: 12rpx;
}
.history-progress-wrap { display: flex; align-items: center; gap: 12rpx; }
.history-progress-bar {
  flex: 1;
  height: 6rpx;
  background: var(--color-border);
  border-radius: 3rpx;
  overflow: hidden;
}
.history-progress-inner {
  height: 100%;
  background: var(--color-gold);
  border-radius: 3rpx;
}
.history-pct { font-size: 20rpx; color: var(--color-brown); white-space: nowrap; }
.history-continue {
  font-size: 28rpx;
  color: var(--color-gold);
  flex-shrink: 0;
  padding-left: 8rpx;
}
