/* miniprogram/pages/detail/detail.wxss */
.container {
  padding-bottom: 140rpx;
}

.header-section {
  position: relative;
  height: 480rpx;
  overflow: hidden;
  background-color: #1A1410;
}

.bg-blur {
  position: absolute;
  top: -20rpx; left: -20rpx; right: -20rpx; bottom: -20rpx;
  width: calc(100% + 40rpx);
  height: calc(100% + 40rpx);
  filter: blur(40rpx) brightness(0.6);
  z-index: 1;
}

.header-content {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 2;
  display: flex;
  padding: 60rpx 40rpx;
  align-items: flex-end;
}

.book-cover-container {
  position: relative;
  width: 200rpx;
  height: 280rpx;
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.4);
  background: linear-gradient(135deg, #3a2e24, #1a1410);
}

.book-cover {
  width: 100%;
  height: 100%;
}

.cover-placeholder {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  color: rgba(255,255,255,0.6);
  font-size: 24rpx;
  text-align: center;
  word-break: break-all;
}

.book-info {
  margin-left: 40rpx;
  flex: 1;
  color: #fff;
  display: flex;
  flex-direction: column;
}

.book-title {
  font-size: 40rpx;
  font-weight: bold;
  line-height: 1.4;
}

.book-author {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 12rpx;
}

.tags {
  margin-top: 20rpx;
}

.tag {
  display: inline-block;
  background: rgba(255,255,255,0.15);
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #E8DFD0;
  margin-right: 12rpx;
}

.ai-tag {
  background: rgba(212, 170, 80, 0.2);
  color: #D4AA50;
  border: 1rpx solid rgba(212, 170, 80, 0.4);
  animation: pulse 1.5s infinite;
}

.content-section {
  padding: 40rpx 30rpx;
  background: var(--color-bg);
  border-radius: 24rpx 24rpx 0 0;
  margin-top: -24rpx;
  position: relative;
  z-index: 3;
}

.block {
  margin-bottom: 40rpx;
}

.block-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.ai-icon {
  background: var(--color-gold);
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
  font-family: sans-serif;
}

.block-text {
  font-size: 28rpx;
  color: var(--color-text-sub);
  line-height: 1.8;
  text-align: justify;
}

.ai-block {
  background: var(--color-bg-card);
  padding: 30rpx;
  border-radius: var(--radius-card);
  box-shadow: 0 4rpx 16rpx var(--color-shadow);
}

.ai-text {
  color: var(--color-text);
}

.footer-bar {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  height: 120rpx;
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.action-icons {
  display: flex;
  margin-right: 30rpx;
}

.icon-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 20rpx;
  color: var(--color-text-sub);
}

.action-btns {
  flex: 1;
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.btn-free {
  background: #1A1410;
  color: #D4AA50;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 0 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
}

.btn-ad {
  background: var(--color-bg);
  color: var(--color-text);
  border: 2rpx solid var(--color-border);
  border-radius: 40rpx;
  font-size: 26rpx;
  padding: 0 30rpx;
  height: 80rpx;
  line-height: 76rpx;
  margin: 0;
}

.btn-gold-pay {
  background: linear-gradient(135deg, #D4AA50, #C9A84C);
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 0 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
}

.loading-full {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-text {
  color: var(--color-gold);
  font-size: 32rpx;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0% { opacity: 0.6; }
  50% { opacity: 1; }
  100% { opacity: 0.6; }
}
